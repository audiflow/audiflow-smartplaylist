{
  "id": "categories",
  "displayName": "Story Arcs",
  "resolverType": "category",
  "priority": 50,
  "playlistStructure": "grouped",
  "episodeFilters": {
    "require": [
      { "title": "(?:Main|Bonus)" }
    ],
    "exclude": [
      { "title": "(?:Trailer|Preview)" }
    ]
  },
  "groupList": {
    "showDateRange": true
  },
  "episodeList": {
    "showYearHeaders": true
  },
  "groups": [
    {
      "id": "main",
      "displayName": "Main Episodes",
      "pattern": "^Main\\b"
    },
    {
      "id": "bonus",
      "displayName": "Bonus Content",
      "pattern": "^Bonus\\b"
    },
    {
      "id": "other",
      "displayName": "Other"
    }
  ]
}
