{
  "id": "story-arcs",
  "displayName": "Story Arcs",
  "resolverType": "titleDiscovery",
  "presentation": "combined",
  "episodeFilters": {
    "require": [
      { "title": "\\[.+\\]" }
    ]
  },
  "titleExtractor": {
    "source": "title",
    "pattern": "\\[(.+?)\\s+\\d+\\]",
    "group": 1
  },
  "numberingExtractor": {
    "source": "title",
    "pattern": "\\[.+?\\s+(\\d+)\\]",
    "seasonGroup": null,
    "episodeGroup": 1,
    "fallbackToRss": true
  }
}
