{
  "id": "person",
  "displayName": "パーソナリティ",
  "priority": 0,
  "episodeFilters": {
    "require": [
      {
        "title": "（[^）]+）|\\([^)]+\\)"
      }
    ]
  },
  "grouping": {
    "by": "titleDiscovery"
  },
  "groupListing": {
    "yearBinding": "splitByYear",
    "userSortable": true
  },
  "groupItem": {
    "showDateRange": false,
    "titleExtractor": {
      "source": "title",
      "pattern": "\\(([^)]+)\\)",
      "template": "${1}",
      "fallback": {
        "source": "title",
        "pattern": "（([^）]+)）",
        "template": "${1}"
      }
    }
  },
  "episodeListing": {
    "showYearHeaders": true
  },
  "episodeItem": {
    "titleExtractor": {
      "source": "title",
      "pattern": "^(.*?)[(（][^)）]+[)）]\\s*$",
      "template": "${1}"
    }
  }
}
