{
  "displayName": "パーソナリティ",
  "episodeFilters": {
    "require": [
      {
        "title": "（[^）]+）|\\([^)]+\\)"
      }
    ]
  },
  "episodeList": {
    "showYearHeaders": true
  },
  "groupList": {
    "showDateRange": false,
    "userSortable": true,
    "yearBinding": "splitByYear"
  },
  "id": "person",
  "playlistStructure": "grouped",
  "priority": 10,
  "resolverType": "titleDiscovery",
  "titleExtractor": {
    "fallback": {
      "group": 1,
      "pattern": "（([^）]+)）",
      "source": "title"
    },
    "group": 1,
    "pattern": "\\(([^)]+)\\)",
    "source": "title"
  }
}
