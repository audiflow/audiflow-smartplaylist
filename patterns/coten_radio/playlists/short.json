{
  "id": "short",
  "displayName": "ショートシリーズ",
  "resolverType": "rss",
  "priority": 20,
  "contentType": "groups",
  "yearHeaderMode": "firstEpisode",
  "showDateRange": true,
  "showSortOrderToggle": true,
  "titleFilter": "【\\d+-\\d+】",
  "requireFilter": "【COTEN RADIO\\s*ショート",
  "nullSeasonGroupKey": 0,
  "groups": [],
  "customSort": {
    "rules": [
      {
        "field": "playlistNumber",
        "order": "ascending"
      }
    ]
  },
  "titleExtractor": {
    "source": "title",
    "pattern": "【COTEN RADIOショート\\s+(.+?)編?\\s*(\\d+|前編|中編|後編)】",
    "group": 1,
    "fallback": {
      "source": "title",
      "pattern": "【COTEN RADIOショート\\s+(.+?)\\s*(\\d+|前編|中編|後編)】"
    },
    "fallbackValue": "番外編"
  },
  "smartPlaylistEpisodeExtractor": {
    "source": "title",
    "pattern": "【(\\d+)-(\\d+)】",
    "seasonGroup": 1,
    "episodeGroup": 2,
    "fallbackSeasonNumber": 0,
    "fallbackEpisodePattern": "【番外編[＃#](\\d+)】",
    "fallbackToRss": true
  }
}
