{
  "id": "regular",
  "displayName": "レギュラーシリーズ",
  "resolverType": "rss",
  "priority": 10,
  "contentType": "groups",
  "yearHeaderMode": "firstEpisode",
  "showDateRange": true,
  "showSortOrderToggle": true,
  "titleFilter": "【\\d+-\\d+】",
  "excludeFilter": "【COTEN RADIO\\s*ショート",
  "nullSeasonGroupKey": 0,
  "groups": [],
  "customSort": {
    "rules": [
      {
        "field": "playlistNumber",
        "order": "ascending"
      }
    ]
  },
  "titleExtractor": {
    "source": "title",
    "pattern": "【COTEN RADIO\\s*([^】]+)編\\s*(\\d+)】",
    "group": 1,
    "fallback": {
      "source": "title",
      "pattern": "【COTEN RADIO\\s*(.+?)\\s*(\\d+)】",
      "group": 1
    },
    "fallbackValue": "その他"
  },
  "smartPlaylistEpisodeExtractor": {
    "source": "title",
    "pattern": "【(\\d+)-(\\d+)】",
    "seasonGroup": 1,
    "episodeGroup": 2,
    "fallbackSeasonNumber": 0,
    "fallbackEpisodePattern": "(\\d+)】",
    "fallbackToRss": true
  }
}
