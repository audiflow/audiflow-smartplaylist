{
  "id": "short",
  "displayName": "ショートシリーズ",
  "priority": 1,
  "episodeFilters": {
    "require": [
      {
        "title": "【\\d+-\\d+】"
      },
      {
        "title": "【COTEN RADIO\\s*ショート"
      }
    ]
  },
  "grouping": {
    "by": "seasonNumber",
    "numberingExtractor": {
      "source": "title",
      "pattern": "【(\\d+)-(\\d+)】",
      "seasonGroup": 1,
      "episodeGroup": 2,
      "fallbackSeasonNumber": 0,
      "fallbackEpisodePattern": "【番外編[＃#](\\d+)】",
      "fallbackToRss": true
    }
  },
  "groupListing": {
    "yearBinding": "pinToYear",
    "userSortable": true,
    "sort": {
      "field": "playlistNumber",
      "order": "ascending"
    }
  },
  "groupItem": {
    "showDateRange": true,
    "titleExtractor": {
      "source": "title",
      "pattern": "【COTEN RADIOショート\\s+(.+?)編?\\s*(\\d+|前編|中編|後編)】",
      "group": 1,
      "fallback": {
        "source": "title",
        "pattern": "【COTEN RADIOショート\\s+(.+?)\\s*(\\d+|前編|中編|後編)】"
      },
      "fallbackValue": "番外編"
    }
  }
}
