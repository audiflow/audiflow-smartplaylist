{
  "id": "regular",
  "displayName": "レギュラーシリーズ",
  "priority": 0,
  "episodeFilters": {
    "require": [
      {
        "title": "【\\d+-\\d+】"
      }
    ],
    "exclude": [
      {
        "title": "【COTEN RADIO\\s*ショート"
      }
    ]
  },
  "grouping": {
    "by": "seasonNumber",
    "numberingExtractor": {
      "source": "title",
      "pattern": "【(\\d+)-(\\d+)】",
      "seasonGroup": 1,
      "episodeGroup": 2,
      "fallbackSeasonNumber": 0,
      "fallbackEpisodePattern": "(\\d+)】",
      "fallbackToRss": true
    }
  },
  "groupListing": {
    "yearBinding": "pinToYear",
    "userSortable": true,
    "sort": {
      "field": "playlistNumber",
      "order": "ascending"
    }
  },
  "groupItem": {
    "showDateRange": true,
    "titleExtractor": {
      "source": "title",
      "pattern": "【COTEN RADIO\\s*([^】]+)編\\s*(\\d+)】",
      "group": 1,
      "fallback": {
        "source": "title",
        "pattern": "【COTEN RADIO\\s*(.+?)\\s*(\\d+)】",
        "group": 1
      },
      "fallbackValue": "その他"
    }
  }
}
