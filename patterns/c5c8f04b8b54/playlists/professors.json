{
  "id": "professors",
  "displayName": "ゲスト別",
  "priority": 0,
  "grouping": {
    "by": "titleDiscovery"
  },
  "selector": {
    "partitionBy": "seasonNumber",
    "titleExtractor": {
      "source": "seasonNumber",
      "template": "シーズン ${0}"
    }
  },
  "groupListing": {
    "userSortable": true,
    "sort": {
      "field": "playlistNumber",
      "order": "ascending"
    }
  },
  "groupItem": {
    "showDateRange": true,
    "titleExtractor": {
      "source": "title",
      "pattern": "【(?:出演：)?(.+?)\\s*編",
      "template": "${1}",
      "fallback": {
        "source": "title",
        "pattern": "【(?:出演：)?(.+?)\\s*】",
        "template": "${1}"
      }
    }
  },
  "episodeItem": {
    "titleExtractor": {
      "source": "title",
      "pattern": "#\\d+(?:-\\d+)?\\s+(.+?)\\s*【",
      "template": "${1}"
    }
  }
}
