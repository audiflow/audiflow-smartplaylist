{
  "displayName": "テーマ回",
  "episodeFilters": {
    "exclude": [
      {
        "title": "番外編|雑談回|特別編"
      }
    ],
    "require": [
      {
        "title": "（その\\d+|[前中後]編）"
      }
    ]
  },
  "episodeList": {
    "titleExtractor": {
      "group": 1,
      "pattern": "^#\\d+ (.*?)[／：]",
      "source": "title"
    }
  },
  "groupList": {
    "showDateRange": true,
    "sort": {
      "field": "newestEpisodeDate",
      "order": "ascending"
    },
    "userSortable": true,
    "yearBinding": "pinToYear"
  },
  "id": "topics",
  "nullSeasonGroupKey": 0,
  "playlistStructure": "grouped",
  "priority": 10,
  "resolverType": "titleAppearanceOrder",
  "titleExtractor": {
    "group": 1,
    "pattern": "^#\\d+ *?(.*?)(?:[／：]|（その\\d+|[前中後]編）)",
    "source": "title"
  }
}
