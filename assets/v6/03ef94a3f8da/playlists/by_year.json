{
  "displayName": "年別",
  "groupListing": {
    "userSortable": true,
    "yearBinding": "splitByYear"
  },
  "grouping": {
    "by": "titleClassifier",
    "staticClassifiers": [
      {
        "displayName": "平日版",
        "id": "daily_news",
        "pattern": {
          "pattern": "【\\d+月\\d+日】",
          "source": "title"
        }
      },
      {
        "displayName": "土曜版",
        "id": "saturday",
        "pattern": {
          "pattern": "【土曜版",
          "source": "title"
        }
      },
      {
        "displayName": "ニュース小話",
        "id": "news_talk",
        "pattern": {
          "pattern": "【ニュース小話",
          "source": "title"
        }
      },
      {
        "displayName": "特別編",
        "id": "special",
        "pattern": {
          "pattern": "【.*?特別編.*?】",
          "source": "title"
        }
      },
      {
        "displayName": "越境日本人編",
        "id": "expat",
        "pattern": {
          "pattern": "【越境日本人編",
          "source": "title"
        }
      },
      {
        "displayName": "祝日版",
        "id": "holiday",
        "pattern": {
          "pattern": "【祝日版",
          "source": "title"
        }
      },
      {
        "displayName": "その他",
        "id": "other"
      }
    ]
  },
  "id": "by_year",
  "priority": 1
}
